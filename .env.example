# Banco de dados PostgreSQL (no Railway, use a variável do plugin Postgres)
DATABASE_URL="postgresql://user:password@localhost:5432/fluxo"

# Segredo para assinar os tokens de login (gere um valor aleatório longo)
JWT_SECRET="troque-por-um-valor-aleatorio-bem-longo"

# Pasta onde os anexos são salvos. No Railway, use /data e monte um Volume em /data.
UPLOAD_DIR="./uploads"

# Chave de API para o servidor MCP (controlar o Fluxo pelo Claude). Gere com: openssl rand -hex 24
FLUXO_API_KEY="troque-por-uma-chave-secreta-forte"

# Usuário admin inicial criado pelo seed (npm run db:seed)
SEED_ADMIN_NAME="Giancarlo Gariglia"
SEED_ADMIN_EMAIL="giancarlogariglia@gmail.com"
SEED_ADMIN_PASSWORD="troque-esta-senha"

# Token da API do ClickUp para a importação (ClickUp > Settings > Apps > API Token)
CLICKUP_API_TOKEN="pk_xxxxxxxx"
# Opcional: limitar a workspaces específicos
# CLICKUP_TEAM_IDS="9011900827,90132851675"
# Opcional: importar comentários também (mais lento)
# IMPORT_COMMENTS="true"
