// Fluxo — schema do banco (réplica simplificada do ClickUp)
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Company {
  id        String   @id @default(cuid())
  name      String
  active    Boolean  @default(true)
  clickupId String?  @unique
  createdAt DateTime @default(now())

  // Módulos ligáveis por empresa (csv): tarefas,chat,docs,financeiro...
  modules   String   @default("tarefas,chat,docs,financeiro")

  workspaces Workspace[]
  users      User[]
  accessUsers User[]    @relation("CompanyAccess")
  channels   Channel[]
  documents  Document[]
  sprints    Sprint[]
  credores       Credor[]
  paymentRequests PaymentRequest[]
  approverConfigs ApproverConfig[]
  categorias     Categoria[]
  categoriaRegras CategoriaRegra[]
  departamentos  Departamento[]
  contas         BankAccount[]
  integrations   IntegrationConfig[]
  clientes       Cliente[]
  planos         Plano[]
  assinaturas    Assinatura[]
  recebiveis     Receivable[]
  onboardingLinks OnboardingLink[]
  documentos Documento[]
  driveConn DriveConn?
  fechadoAte DateTime? // financeiro fechado ate esta data (trava de periodo)
  gruposSessao GrupoSessao[]
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String?
  role         String   @default("member") // owner | admin | member
  status       String   @default("pending") // pending | active | disabled
  color        String   @default("#6366f1")
  clickupId    String?  @unique
  createdAt    DateTime @default(now())

  // Verificação de e-mail e redefinição de senha (Resend)
  emailVerified Boolean   @default(true)
  verifyToken   String?   @unique
  resetToken    String?   @unique
  resetTokenExp DateTime?

  // Token pessoal pro conector do Claude (MCP) — cada usuário opera como ele mesmo
  mcpToken String? @unique

  // PIN de pagamento (2º fator pra aprovar pagamentos). Hash — nunca em texto.
  paymentPinHash String?

  companyId String?
  company   Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)

  // Empresas adicionais que a pessoa pode visualizar (além da empresa-base).
  companyAccess Company[] @relation("CompanyAccess")

  assignedTasks Task[]        @relation("TaskAssignees")
  comments      Comment[]
  chatMessages  ChatMessage[]
  notifications Notification[]
  spaceAccess   Space[]       @relation("SpaceMembers")
  listAccess    List[]        @relation("ListMembers")
  activities    Activity[]
  channelMemberships Channel[]     @relation("ChannelMembers")
  reactions          Reaction[]
  channelReads       ChannelRead[]
}

model Workspace {
  id        String   @id @default(cuid())
  name      String
  clickupId String?  @unique
  createdAt DateTime @default(now())

  companyId String?
  company   Company? @relation(fields: [companyId], references: [id], onDelete: Cascade)

  spaces Space[]
  tags   Tag[]

  @@index([companyId])
}

model Space {
  id          String  @id @default(cuid())
  name        String
  color       String  @default("#6366f1")
  order       Int     @default(0)
  clickupId   String? @unique
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  private Boolean @default(false)
  members User[]  @relation("SpaceMembers")

  folders Folder[]
  lists   List[]
}

model Folder {
  id        String  @id @default(cuid())
  name      String
  order     Int     @default(0)
  clickupId String? @unique
  spaceId   String
  space     Space   @relation(fields: [spaceId], references: [id], onDelete: Cascade)

  lists List[]
}

model List {
  id        String  @id @default(cuid())
  name      String
  order     Int     @default(0)
  clickupId String? @unique
  spaceId   String?
  space     Space?  @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  folderId  String?
  folder    Folder? @relation(fields: [folderId], references: [id], onDelete: Cascade)

  private Boolean @default(false)
  members User[]  @relation("ListMembers")

  statuses Status[]
  tasks    Task[]
}

model Status {
  id        String  @id @default(cuid())
  name      String
  color     String  @default("#a3a3a3")
  order     Int     @default(0)
  type      String  @default("custom") // open | custom | closed | done
  listId    String
  list      List    @relation(fields: [listId], references: [id], onDelete: Cascade)

  tasks Task[]

  @@index([listId])
}

model Task {
  id          String    @id @default(cuid())
  name        String
  description String?   @db.Text
  priority    String?   // urgent | high | normal | low
  dueDate     DateTime?
  startDate   DateTime?
  dateClosed  DateTime?
  order       Float     @default(0)
  customFields Json?
  clickupId   String?   @unique
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  points   Int?
  sprintId String?
  sprint   Sprint? @relation(fields: [sprintId], references: [id], onDelete: SetNull)

  listId   String
  list     List   @relation(fields: [listId], references: [id], onDelete: Cascade)
  statusId String?
  status   Status? @relation(fields: [statusId], references: [id], onDelete: SetNull)

  parentId String?
  parent   Task?   @relation("Subtasks", fields: [parentId], references: [id], onDelete: Cascade)
  subtasks Task[]  @relation("Subtasks")

  assignees   User[]       @relation("TaskAssignees")
  tags        Tag[]        @relation("TaskTags")
  comments    Comment[]
  attachments Attachment[]

  // Dependências (auto-relação N:N): blockedBy = tarefas que travam esta; blocking = tarefas que esta trava
  blockedBy Task[] @relation("TaskDeps")
  blocking  Task[] @relation("TaskDeps")

  activities Activity[]

  @@index([listId])
  @@index([statusId])
}

model Activity {
  id        String   @id @default(cuid())
  type      String   // created | renamed | status | priority | assignees | due | moved | comment
  text      String
  createdAt DateTime @default(now())

  taskId String
  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)
  userId String?
  user   User?  @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([taskId])
}

model Attachment {
  id         String   @id @default(cuid())
  filename   String
  mime       String   @default("application/octet-stream")
  size       Int      @default(0)
  storedName String   // unique name on disk / storage key
  createdAt  DateTime @default(now())

  taskId String?
  task   Task?   @relation(fields: [taskId], references: [id], onDelete: Cascade)

  messageId String?
  message   ChatMessage? @relation(fields: [messageId], references: [id], onDelete: Cascade)

  requestId String?
  request   PaymentRequest? @relation(fields: [requestId], references: [id], onDelete: Cascade)
  tag       String?  // nf | comprovante | cotacao | boleto | outro

  @@index([taskId])
  @@index([messageId])
  @@index([requestId])
}

model Tag {
  id          String @id @default(cuid())
  name        String
  color       String @default("#a3a3a3")
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  tasks Task[] @relation("TaskTags")

  @@unique([workspaceId, name])
}

model Comment {
  id        String   @id @default(cuid())
  text      String   @db.Text
  clickupId String?  @unique
  createdAt DateTime @default(now())

  taskId String
  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)
  userId String?
  user   User?  @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([taskId])
}

model Channel {
  id        String   @id @default(cuid())
  name      String
  kind      String   @default("channel") // channel | dm
  createdAt DateTime @default(now())

  companyId String?
  company   Company? @relation(fields: [companyId], references: [id], onDelete: Cascade)

  members  User[]        @relation("ChannelMembers")
  messages ChatMessage[]
  reads    ChannelRead[]

  @@index([companyId])
}

model ChatMessage {
  id        String   @id @default(cuid())
  text      String   @db.Text
  createdAt DateTime @default(now())
  editedAt  DateTime?

  channelId String
  channel   Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  userId    String?
  user      User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  parentId String?
  parent   ChatMessage?  @relation("MsgThread", fields: [parentId], references: [id], onDelete: Cascade)
  replies  ChatMessage[] @relation("MsgThread")

  reactions   Reaction[]
  attachments Attachment[]

  @@index([channelId])
  @@index([parentId])
}

model Reaction {
  id        String   @id @default(cuid())
  emoji     String
  createdAt DateTime @default(now())

  messageId String
  message   ChatMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  userId    String
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId, emoji])
  @@index([messageId])
}

model ChannelRead {
  id         String   @id @default(cuid())
  lastReadAt DateTime @default(now())

  channelId String
  channel   Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  userId    String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([channelId, userId])
  @@index([userId])
}

model Sprint {
  id        String   @id @default(cuid())
  name      String
  startDate DateTime?
  endDate   DateTime?
  goal      String?
  createdAt DateTime @default(now())

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  tasks     Task[]

  @@index([companyId])
}

model Document {
  id        String   @id @default(cuid())
  title     String
  content   String   @db.Text @default("")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  companyId String?
  company   Company? @relation(fields: [companyId], references: [id], onDelete: Cascade)
  authorId  String?

  @@index([companyId])
}

model Notification {
  id        String   @id @default(cuid())
  type      String   // assigned | mention | due | finance
  text      String
  link      String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
}

// ===== Módulo Financeiro =====

// Credor/Favorecido — cadastro único por CPF/CNPJ (mata o "mesmo nome de 3 jeitos").
model Credor {
  id        String   @id @default(cuid())
  nome      String
  documento String   // CPF/CNPJ (chave única dentro da empresa)
  tipo      String   @default("fornecedor") // fornecedor | profissional | funcionario | socio | locador | concessionaria | orgao
  pixKey    String?
  bankInfo  String?
  categoriaPadrao String?
  createdAt DateTime @default(now())

  companyId String
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  requests  PaymentRequest[]

  @@index([companyId])
}

// Solicitação de Pagamento (Portal) — fluxo padrão ou reembolso, 3 portões.
model PaymentRequest {
  id        String   @id @default(cuid())
  code      Int      @default(autoincrement())
  kind      String   @default("padrao") // padrao | reembolso
  status    String   @default("solicitada") // solicitada | aprovada_gestor | conferida | paga | recusada | cancelada

  companyId String
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  spaceId   String?  // área = Espaço da empresa
  areaName  String   @default("")

  credorId  String?
  credor    Credor?  @relation(fields: [credorId], references: [id], onDelete: SetNull)

  descricao String   @db.Text @default("")
  valor     Float    @default(0)
  vencimento DateTime?
  formaPagamento String? // pix | boleto | transferencia | guia | cartao

  // Classificação (financeiro)
  categoriaId     String?
  categoriaRef    Categoria? @relation(fields: [categoriaId], references: [id], onDelete: SetNull)
  categoria       String?  // texto resolvido "Grupo › Categoria" (histórico/Omie)
  departamentoId  String?
  departamento    Departamento? @relation(fields: [departamentoId], references: [id], onDelete: SetNull)
  centroCusto     String?
  classeGerencial String?

  // Documento fiscal
  docTipo   String?  // nf | boleto | recibo | contrato | fatura
  docNumero String?

  // Cotação (padrão acima de R$ 400)
  cotacaoDispensa      Boolean @default(false)
  cotacaoJustificativa String?

  recorrencia String @default("unica") // unica | mensal
  prazoPagamento String? // à vista | 7 | 15 | 30 | data | parcelado
  prioridade     String? // normal | alta | urgente
  observacao     String? @db.Text

  // Pagamento
  contaOrigem   String?
  dataPagamento DateTime?

  // Execução de pagamento pelo banco (Inter), com aprovação do pagador.
  pagDestinoTipo String?  // pix | boleto
  pagDestino     String?  // chave Pix OU código de barras do credor
  pagBankStatus  String   @default("nenhum") // nenhum | aguardando_app | enviado | pago | falhou
  pagBankRef     String?  // id da transação no Inter
  pagRequerApp   Boolean  @default(false) // acima do teto: precisa confirmar no app do Inter
  pagAprovadoPor String?  // userId do pagador que aprovou
  pagAprovadoEm  DateTime?
  pagErro        String?

  // Pessoas envolvidas (ids; nomes resolvidos na API)
  solicitanteId String?
  gestorId      String?
  financeiroId  String?
  pagadorId     String?

  recusaMotivo String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  attachments Attachment[]
  steps       RequestStep[]

  @@index([companyId, status])
}

// Trilha de auditoria de cada etapa da solicitação.
model RequestStep {
  id        String   @id @default(cuid())
  action    String   // criada | aprovada_gestor | conferida | paga | recusada | editada | comentario
  fromStatus String?
  toStatus   String?
  note      String?
  userId    String?
  userName  String?
  createdAt DateTime @default(now())

  requestId String
  request   PaymentRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@index([requestId])
}

// Plano de contas (categorias do Omie): Grupo › Categoria, por empresa.
model Categoria {
  id        String   @id @default(cuid())
  grupo     String   // ex.: "04. Despesas Administrativas"
  nome      String   // ex.: "Aluguel"
  tipo      String   @default("despesa") // receita | despesa
  // Fluxo de caixa (DFC): bloco do demonstrativo.
  bloco     String   @default("operacional") // operacional | investimento | financiamento
  dre       String?  // Conta do DRE (Omie)
  ativo     Boolean  @default(true)
  ordem     Int      @default(0)
  createdAt DateTime @default(now())

  companyId String
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  requests  PaymentRequest[]
  regras    CategoriaRegra[]

  @@unique([companyId, grupo, nome])
  @@index([companyId, tipo])
  @@index([companyId, bloco])
  bankTransactions BankTransaction[] @relation("BankTxCategoria")
}

// Regra de auto-categorização do extrato: se a contraparte casar com 'padrao',
// classifica o lançamento na categoria indicada. Avaliadas por 'prioridade' (maior primeiro).
model CategoriaRegra {
  id         String   @id @default(cuid())
  padrao     String   // texto a procurar na descrição (case-insensitive), ex.: "BELOTTI"
  aplicaA    String   @default("ambos") // credito | debito | ambos
  prioridade Int      @default(0)
  createdAt  DateTime @default(now())

  companyId   String
  company     Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  categoriaId String
  categoria   Categoria @relation(fields: [categoriaId], references: [id], onDelete: Cascade)

  @@index([companyId])
}

// Conta bancária da empresa. O caixa é a soma de todas.
model BankAccount {
  id        String   @id @default(cuid())
  nome      String   // ex.: "Inter PJ", "C6 PJ", "Nubank PJ"
  banco     String?  // inter | c6 | nubank | outro
  conexao   String   @default("manual") // inter (API) | manual (importa extrato)
  ordem     Int      @default(0)
  ativo     Boolean  @default(true)
  createdAt DateTime @default(now())

  companyId String
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  transacoes BankTransaction[]

  @@index([companyId])
  tipo      String  @default("caixa") // caixa | cartao
  lastSyncAt DateTime?
}

// Lançamento de extrato (de conta manual importada OU sincronizado do Inter).
model BankTransaction {
  id         String   @id @default(cuid())
  data       DateTime
  valor      Float    // positivo = crédito, negativo = débito
  tipo       String   // credito | debito
  descricao  String   @db.Text @default("")
  origem     String   @default("import") // import | inter_api
  fitId      String?  // id único do lançamento (OFX FITID / Inter) p/ dedupe
  // Classificação e conciliação
  categoriaId String?
  categoria   Categoria? @relation("BankTxCategoria", fields: [categoriaId], references: [id], onDelete: SetNull)
  departamentoId String?
  conciliado Boolean @default(false)
  requestId  String?  // amarrado a uma conta a pagar/receber
  importLote String?

  accountId  String
  account    BankAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  companyId  String

  @@index([companyId, data])
  @@index([accountId, data])
  @@unique([accountId, fitId])
}

// Departamento (centro de custo): a ÁREA que gastou. Dimensão separada da categoria.
model Departamento {
  id        String   @id @default(cuid())
  nome      String
  ordem     Int      @default(0)
  gestorId  String?  // usuário que aprova a 1ª alçada da área
  ativo     Boolean  @default(true)
  createdAt DateTime @default(now())

  companyId String
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  requests  PaymentRequest[]

  @@unique([companyId, nome])
  @@index([companyId])
}

// Configuração de aprovadores por empresa (gestor por área; financeiro e pagador por empresa).
model ApproverConfig {
  id        String   @id @default(cuid())
  role      String   // gestor | financeiro | pagador
  spaceId   String?  // usado só p/ gestor (por área)
  userId    String
  createdAt DateTime @default(now())

  companyId String
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId, role])
}

// ===== Módulo Contas a Receber (integração Iugu) =====

// Credenciais e config de integração de pagamento por empresa. O token NUNCA é exposto ao cliente.
model IntegrationConfig {
  id           String   @id @default(cuid())
  provider     String   @default("iugu") // iugu | inter
  apiToken     String   @default("")  // Iugu: token. (segredo — só servidor)
  accountId    String?  // Account ID da Iugu (opcional)
  webhookToken String   // segredo aleatório usado na URL do webhook
  testMode     Boolean  @default(false)
  connectedAt  DateTime @default(now())
  lastSyncAt   DateTime?

  // Credenciais de banco (Inter): mTLS + OAuth. Tudo segredo, nunca exposto ao cliente.
  clientId      String?
  clientSecret  String?
  certPem       String?  @db.Text
  keyPem        String?  @db.Text
  contaCorrente String?
  pixKey        String?  // chave Pix de recebimento
  // Teto (em centavos) abaixo do qual a aprovação na Sandra paga direto;
  // acima dele, exige também confirmação no app do Inter.
  tetoPagamentoCents Int @default(500000)

  companyId String
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, provider])
}

// Cliente/pagador (lado do Contas a Receber). Espelha o customer da Iugu.
model Cliente {
  id             String   @id @default(cuid())
  nome           String
  email          String
  documento      String?  // CPF/CNPJ (legado — em migração para documentoEnc)
  documentoEnc   String?  @db.Text // CPF/CNPJ cifrado em repouso (AES-256-GCM)
  telefone       String?
  rg             String?
  cep            String?
  logradouro     String?
  numero         String?
  complemento    String?
  bairro         String?
  cidade         String?
  uf             String?
  iuguCustomerId String?  // id do customer na Iugu
  ativo          Boolean  @default(true)
  // LGPD — dado de saúde/financeiro é categoria especial: registramos consentimento.
  consentimentoLGPD Boolean  @default(false)
  consentimentoEm   DateTime?
  consentimentoBase String?  // finalidade/base legal (ex.: "execução de contrato")
  createdAt      DateTime @default(now())

  companyId String
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  assinaturas Assinatura[]
  recebiveis  Receivable[]

  @@index([companyId])
  @@index([iuguCustomerId])
  documentos Documento[]
  presencasSessao SessaoPresenca[]
}

// Plano de recorrência. Espelha o plan da Iugu.
model Plano {
  id           String   @id @default(cuid())
  nome         String
  identifier   String   // identifier do plano na Iugu (tag)
  valorCents   Int      @default(0)
  intervalo    Int      @default(1)        // quantidade
  intervaloTipo String  @default("months") // months | weeks
  payableWith  String   @default("bank_slip,pix,credit_card") // csv
  iuguPlanId   String?
  ativo        Boolean  @default(true)
  createdAt    DateTime @default(now())

  companyId String
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  assinaturas Assinatura[]

  @@unique([companyId, identifier])
  @@index([companyId])
  onboardingLinks OnboardingLink[]
}

// Assinatura de um cliente a um plano. Espelha a subscription da Iugu.
model Assinatura {
  id                 String   @id @default(cuid())
  status             String   @default("ativa") // ativa | suspensa | expirada | cancelada
  iuguSubscriptionId String?
  proximaCobranca    DateTime?
  valorCents         Int?      // valor por paciente (sobrepõe o do plano)
  diaCobranca        Int?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  companyId String
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  clienteId String
  cliente   Cliente  @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  planoId   String
  plano     Plano    @relation(fields: [planoId], references: [id], onDelete: Cascade)
  recebiveis Receivable[]

  @@index([companyId, status])
  @@index([iuguSubscriptionId])
}

// Conta a Receber = fatura (invoice da Iugu). Pode vir de assinatura ou cobrança avulsa.
model Receivable {
  id            String   @id @default(cuid())
  descricao     String   @default("")
  valorCents    Int      @default(0)
  status        String   @default("pendente") // pendente | paga | vencida | cancelada | estornada | em_protesto
  metodo        String?  // bank_slip | pix | credit_card
  vencimento    DateTime?
  pagoEm        DateTime?
  provider      String   @default("iugu") // iugu | inter
  externalId    String?  // txid (Inter) / invoice id (Iugu)
  endToEndId    String?  // Pix E2E (conciliação exata)
  pixCopiaECola String?  @db.Text
  iuguInvoiceId String?  @unique
  secureUrl     String?  // link da fatura / QR (Pix/boleto)
  origem        String   @default("avulsa") // avulsa | assinatura
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  companyId String
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  clienteId String?
  cliente   Cliente? @relation(fields: [clienteId], references: [id], onDelete: SetNull)
  assinaturaId String?
  assinatura   Assinatura? @relation(fields: [assinaturaId], references: [id], onDelete: SetNull)

  @@unique([provider, externalId])
  @@index([companyId, status])
  @@index([companyId, vencimento])
}

// ===== Segurança / LGPD =====
// Trilha de auditoria de acesso e alteração de dados sensíveis (financeiro + paciente).
// Quem fez, o quê, em qual registro, quando e de qual IP. Append-only.
model AuditLog {
  id        String   @id @default(cuid())
  at        DateTime @default(now())
  userId    String?
  userName  String?
  action    String   // view | create | update | delete | export | pay | login
  entity    String   // extrato | solicitacao | recebivel | cobranca | cliente | paciente | config
  entityId  String?
  companyId String?
  ip        String?
  meta      String?  @db.Text // detalhe curto (ex.: período do extrato, valor)

  @@index([companyId, at])
  @@index([entity, entityId])
  @@index([userId, at])
}

model OnboardingLink {
  id         String   @id @default(cuid())
  token      String   @unique
  label      String?
  valorCents Int?      // sobrepõe o valor do plano, se informado
  diaCobranca Int?
  ativo      Boolean  @default(true)
  usos       Int      @default(0)
  createdAt  DateTime @default(now())

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  planoId   String
  plano     Plano   @relation(fields: [planoId], references: [id], onDelete: Cascade)

  @@index([companyId])
}

model Documento {
  id         String   @id @default(cuid())
  companyId  String
  company    Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  clienteId  String?
  cliente    Cliente? @relation(fields: [clienteId], references: [id], onDelete: SetNull)
  credorId   String?
  tipo       String   @default("outro") // contrato | nf | comprovante | outro
  filename   String
  mime       String   @default("application/octet-stream")
  size       Int      @default(0)
  conteudo   String   @db.Text          // base64 (durável no banco)
  driveFileId String?                   // quando sincronizado pro Google Drive
  uploadedBy String?
  createdAt  DateTime @default(now())

  @@index([companyId])
  @@index([clienteId])
}

model DriveConn {
  id              String   @id @default(cuid())
  companyId       String   @unique
  company         Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  refreshTokenEnc String   @db.Text
  folderId        String?
  email           String?
  createdAt       DateTime @default(now())
}

model GrupoSessao {
  id        String   @id @default(cuid())
  companyId String
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  data      DateTime
  titulo    String   @default("Sessão em grupo")
  createdAt DateTime @default(now())
  presencas SessaoPresenca[]
  @@index([companyId, data])
}

model SessaoPresenca {
  id         String      @id @default(cuid())
  sessaoId   String
  sessao     GrupoSessao @relation(fields: [sessaoId], references: [id], onDelete: Cascade)
  clienteId  String
  cliente    Cliente     @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  presente   Boolean     @default(false)
  marcado    Boolean     @default(false)
  motivo     String?
  observacao String?     @db.Text
  updatedAt  DateTime    @updatedAt
  @@unique([sessaoId, clienteId])
  @@index([clienteId])
}

model RotinaMetricaLog {
  id        String   @id @default(cuid())
  listId    String
  itemId    String
  itemNome  String
  label     String
  tipo      String   @default("numero")
  valor     String   @default("")
  data      String   // YYYY-MM-DD (dia do snapshot)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@unique([itemId, label, data])
  @@index([listId, data])
}
