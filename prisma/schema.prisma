// Fluxo — schema do banco (réplica simplificada do ClickUp)
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Company {
  id        String   @id @default(cuid())
  name      String
  active    Boolean  @default(true)
  clickupId String?  @unique
  createdAt DateTime @default(now())

  workspaces Workspace[]
  users      User[]
  channels   Channel[]
  documents  Document[]
  sprints    Sprint[]
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String?
  role         String   @default("member") // owner | admin | member
  status       String   @default("pending") // pending | active | disabled
  color        String   @default("#6366f1")
  clickupId    String?  @unique
  createdAt    DateTime @default(now())

  // Verificação de e-mail e redefinição de senha (Resend)
  emailVerified Boolean   @default(true)
  verifyToken   String?   @unique
  resetToken    String?   @unique
  resetTokenExp DateTime?

  // Token pessoal pro conector do Claude (MCP) — cada usuário opera como ele mesmo
  mcpToken String? @unique

  companyId String?
  company   Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)

  assignedTasks Task[]        @relation("TaskAssignees")
  comments      Comment[]
  chatMessages  ChatMessage[]
  notifications Notification[]
  spaceAccess   Space[]       @relation("SpaceMembers")
  listAccess    List[]        @relation("ListMembers")
  activities    Activity[]
  channelMemberships Channel[]     @relation("ChannelMembers")
  reactions          Reaction[]
  channelReads       ChannelRead[]
}

model Workspace {
  id        String   @id @default(cuid())
  name      String
  clickupId String?  @unique
  createdAt DateTime @default(now())

  companyId String?
  company   Company? @relation(fields: [companyId], references: [id], onDelete: Cascade)

  spaces Space[]
  tags   Tag[]

  @@index([companyId])
}

model Space {
  id          String  @id @default(cuid())
  name        String
  color       String  @default("#6366f1")
  order       Int     @default(0)
  clickupId   String? @unique
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  private Boolean @default(false)
  members User[]  @relation("SpaceMembers")

  folders Folder[]
  lists   List[]
}

model Folder {
  id        String  @id @default(cuid())
  name      String
  order     Int     @default(0)
  clickupId String? @unique
  spaceId   String
  space     Space   @relation(fields: [spaceId], references: [id], onDelete: Cascade)

  lists List[]
}

model List {
  id        String  @id @default(cuid())
  name      String
  order     Int     @default(0)
  clickupId String? @unique
  spaceId   String?
  space     Space?  @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  folderId  String?
  folder    Folder? @relation(fields: [folderId], references: [id], onDelete: Cascade)

  private Boolean @default(false)
  members User[]  @relation("ListMembers")

  statuses Status[]
  tasks    Task[]
}

model Status {
  id        String  @id @default(cuid())
  name      String
  color     String  @default("#a3a3a3")
  order     Int     @default(0)
  type      String  @default("custom") // open | custom | closed | done
  listId    String
  list      List    @relation(fields: [listId], references: [id], onDelete: Cascade)

  tasks Task[]

  @@index([listId])
}

model Task {
  id          String    @id @default(cuid())
  name        String
  description String?   @db.Text
  priority    String?   // urgent | high | normal | low
  dueDate     DateTime?
  startDate   DateTime?
  dateClosed  DateTime?
  order       Float     @default(0)
  customFields Json?
  clickupId   String?   @unique
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  points   Int?
  sprintId String?
  sprint   Sprint? @relation(fields: [sprintId], references: [id], onDelete: SetNull)

  listId   String
  list     List   @relation(fields: [listId], references: [id], onDelete: Cascade)
  statusId String?
  status   Status? @relation(fields: [statusId], references: [id], onDelete: SetNull)

  parentId String?
  parent   Task?   @relation("Subtasks", fields: [parentId], references: [id], onDelete: Cascade)
  subtasks Task[]  @relation("Subtasks")

  assignees   User[]       @relation("TaskAssignees")
  tags        Tag[]        @relation("TaskTags")
  comments    Comment[]
  attachments Attachment[]

  // Dependências (auto-relação N:N): blockedBy = tarefas que travam esta; blocking = tarefas que esta trava
  blockedBy Task[] @relation("TaskDeps")
  blocking  Task[] @relation("TaskDeps")

  activities Activity[]

  @@index([listId])
  @@index([statusId])
}

model Activity {
  id        String   @id @default(cuid())
  type      String   // created | renamed | status | priority | assignees | due | moved | comment
  text      String
  createdAt DateTime @default(now())

  taskId String
  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)
  userId String?
  user   User?  @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([taskId])
}

model Attachment {
  id         String   @id @default(cuid())
  filename   String
  mime       String   @default("application/octet-stream")
  size       Int      @default(0)
  storedName String   // unique name on disk / storage key
  createdAt  DateTime @default(now())

  taskId String?
  task   Task?   @relation(fields: [taskId], references: [id], onDelete: Cascade)

  messageId String?
  message   ChatMessage? @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@index([messageId])
}

model Tag {
  id          String @id @default(cuid())
  name        String
  color       String @default("#a3a3a3")
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  tasks Task[] @relation("TaskTags")

  @@unique([workspaceId, name])
}

model Comment {
  id        String   @id @default(cuid())
  text      String   @db.Text
  clickupId String?  @unique
  createdAt DateTime @default(now())

  taskId String
  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)
  userId String?
  user   User?  @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([taskId])
}

model Channel {
  id        String   @id @default(cuid())
  name      String
  kind      String   @default("channel") // channel | dm
  createdAt DateTime @default(now())

  companyId String?
  company   Company? @relation(fields: [companyId], references: [id], onDelete: Cascade)

  members  User[]        @relation("ChannelMembers")
  messages ChatMessage[]
  reads    ChannelRead[]

  @@index([companyId])
}

model ChatMessage {
  id        String   @id @default(cuid())
  text      String   @db.Text
  createdAt DateTime @default(now())
  editedAt  DateTime?

  channelId String
  channel   Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  userId    String?
  user      User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  parentId String?
  parent   ChatMessage?  @relation("MsgThread", fields: [parentId], references: [id], onDelete: Cascade)
  replies  ChatMessage[] @relation("MsgThread")

  reactions   Reaction[]
  attachments Attachment[]

  @@index([channelId])
  @@index([parentId])
}

model Reaction {
  id        String   @id @default(cuid())
  emoji     String
  createdAt DateTime @default(now())

  messageId String
  message   ChatMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  userId    String
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId, emoji])
  @@index([messageId])
}

model ChannelRead {
  id         String   @id @default(cuid())
  lastReadAt DateTime @default(now())

  channelId String
  channel   Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  userId    String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([channelId, userId])
  @@index([userId])
}

model Sprint {
  id        String   @id @default(cuid())
  name      String
  startDate DateTime?
  endDate   DateTime?
  goal      String?
  createdAt DateTime @default(now())

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  tasks     Task[]

  @@index([companyId])
}

model Document {
  id        String   @id @default(cuid())
  title     String
  content   String   @db.Text @default("")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  companyId String?
  company   Company? @relation(fields: [companyId], references: [id], onDelete: Cascade)
  authorId  String?

  @@index([companyId])
}

model Notification {
  id        String   @id @default(cuid())
  type      String   // assigned | mention | due
  text      String
  link      String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
}
